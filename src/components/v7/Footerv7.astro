---
// src/components/v7/Footerv7.astro
---

<footer class="w-full bg-[#EBE4D4] border-t border-[#D4A373]/30">
  
  <div class="relative w-full overflow-hidden pt-8 pb-8">
    
    <img 
      src="/images/v7/footerbg.png" 
      alt="Himalayan Mountains" 
      class="absolute bottom-0 right-0 w-64 md:w-96 lg:w-[30rem] h-auto object-contain opacity-5 pointer-events-none z-0"
      loading="lazy"
    />

    <div class="relative z-10 max-w-6xl mx-auto px-6 md:px-12">
      
      <div class="flex flex-col md:flex-row justify-between items-start gap-8">
        
        <div class="flex flex-col gap-4 w-full md:max-w-sm">
          <img 
            src="/images/v7/logo.png" 
            alt="Himalayan Yogi" 
            class="h-20 md:h-24 w-auto object-contain self-start" 
          />
          
          <div class="flex flex-col gap-1 mt-1">
            <p class="text-[#382B1F] text-sm md:text-base">
              <strong class="font-semibold text-[#2C2117]">Email:</strong> hello@himalayanyogi.com
            </p>
            <p class="text-[#382B1F] text-sm md:text-base">
              <strong class="font-semibold text-[#2C2117]">Phone:</strong> +91 800 123 4567
            </p>

            <div class="flex gap-4 items-center mt-2">
              <a href="https://www.instagram.com/ahimalayanyogi/" class="text-[#382B1F] hover:text-[#8A6345] transition-colors" aria-label="Instagram">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
              </a>
              <a href="https://www.facebook.com/imahimalayanyogi" class="text-[#382B1F] hover:text-[#8A6345] transition-colors" aria-label="Facebook">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
              </a>
            </div>
          </div>

        </div>

        <div class="w-full md:w-auto md:min-w-[16rem]">
          <ul class="flex flex-col w-full border-t border-[#D4A373]/30 md:border-t-0">
            <li class="border-b border-[#D4A373]/30 py-2.5">
              <a href="/about" class="text-[#382B1F] hover:text-[#8A6345] transition-colors text-sm md:text-base">About Us</a>
            </li>
            <li class="border-b border-[#D4A373]/30 py-2.5">
              <a href="/practices" class="text-[#382B1F] hover:text-[#8A6345] transition-colors text-sm md:text-base">Yogic practices</a>
            </li>
            <li class="border-b border-[#D4A373]/30 py-2.5">
              <a href="/programs" class="text-[#382B1F] hover:text-[#8A6345] transition-colors text-sm md:text-base">Programs</a>
            </li>
          </ul>
        </div>

      </div>

    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 md:px-12 pb-4">
    <div class="pt-4 border-t border-[#D4A373]/30 w-full flex justify-center">
      <p class="text-[#382B1F]/60 text-[11px] md:text-xs font-serif text-center">
        &copy; 2026 Himalayan Yogi. All rights reserved.
      </p>
    </div>
  </div>

</footer>