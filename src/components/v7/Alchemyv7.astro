---
// AlchemyV7.astro
---

<section id="programs" class="w-full overflow-hidden flex flex-col bg-[#f9f3e7]">
  
  <div class="w-full py-4 md:py-6 flex flex-col items-center">
    <div class="relative max-w-6xl mx-auto px-6 md:px-12 w-full flex items-center justify-center">
      
      <img 
        src="/images/v7/alchemy.png" 
        alt="Lotus Left" 
        class="hidden md:block absolute left-0 lg:left-12 top-1/2 -translate-y-1/2 w-16 lg:w-24 h-auto object-contain opacity-70 drop-shadow-sm"
        loading="lazy"
      />

      <div class="flex flex-col items-center text-center relative z-10 px-4">
        <h2 class="text-3xl md:text-4xl lg:text-5xl text-[#2C241B] font-medium mb-1 md:mb-1.5" style="font-family: 'Cormorant Garamond', serif;">
          Cultivate the Internal Alchemy
        </h2>
        <p class="text-[11px] md:text-xs text-[#8A6345] tracking-widest uppercase mb-0">
          Inner Chakras
        </p>
      </div>

      <img 
        src="/images/v7/alchemy.png" 
        alt="Lotus Right" 
        class="hidden md:block absolute right-0 lg:right-12 top-1/2 -translate-y-1/2 w-16 lg:w-24 h-auto object-contain opacity-70 drop-shadow-sm"
        loading="lazy"
      />

    </div>
  </div>

  <div class="w-full pb-4 md:pb-8 flex flex-col items-center px-4 md:px-8">
    
    <div class="max-w-5xl mx-auto bg-[#eee7d8] rounded-2xl shadow-sm px-6 md:px-10 py-3 md:py-5 w-full relative">
      
      <div class="hidden md:block absolute top-4 bottom-4 left-1/2 w-[2px] bg-[#D4A373]/50 -translate-x-1/2 z-0 reveal-on-scroll scale-y-0 origin-top transition-transform duration-[1500ms] ease-out" data-animate-type="scale-y"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-0 relative z-10 reveal-on-scroll opacity-0 translate-y-6 transition-all duration-1000 delay-[1200ms] ease-out">
        
        <a href="/practices" class="md:pr-10 lg:pr-14 flex flex-col sm:flex-row gap-4 items-center sm:items-start group transition-transform duration-300 hover:-translate-y-1.5 block">
          <div class="w-20 md:w-28 h-20 md:h-28 shrink-0 rounded-xl shadow-md overflow-hidden bg-white">
            <img src="/images/v7/saptbindu.jpg" alt="Sapt Bindu Sadhana" class="w-full h-full object-cover transform transition-transform duration-[3000ms] ease-out group-hover:scale-110" />
          </div>
          <div class="text-center sm:text-left mt-1">
            <h3 class="text-lg md:text-xl text-[#2C241B] transition-colors duration-1000 ease-out group-hover:text-[#8A6345] font-bold mb-1" style="font-family: 'Cormorant Garamond', serif;">
              Sapt Bindu Sadhana <br/> <span class="font-normal italic text-[#2C241B]/80 transition-colors duration-1000 group-hover:text-[#8A6345]/80">(Kundalini)</span>
            </h3>
            <p class="text-[11px] md:text-xs text-[#2C241B]/80 leading-snug font-serif">
              Re-imagined fine gold line-art of energy coils around the central spine. Awaken the dormant energy and let it rise through the chakras.
            </p>
          </div>
        </a>

        <a href="/practices" class="md:pl-10 lg:pl-14 flex flex-col sm:flex-row gap-4 items-center sm:items-start group transition-transform duration-300 hover:-translate-y-1.5 block">
          <div class="text-center sm:text-right mt-1 order-2 sm:order-1 flex-1">
            <h3 class="text-lg md:text-xl text-[#2C241B] transition-colors duration-1000 ease-out group-hover:text-[#8A6345] font-bold mb-1" style="font-family: 'Cormorant Garamond', serif;">
              Pran Kriya <br/> <span class="font-normal italic text-[#2C241B]/80 transition-colors duration-1000 group-hover:text-[#8A6345]/80">(Life Force)</span>
            </h3>
            <p class="text-[11px] md:text-xs text-[#2C241B]/80 leading-snug font-serif">
              Cultivate life force. Understand the sacred mudras and integrate breath visualization into your daily existence.
            </p>
          </div>
          <div class="w-20 md:w-28 h-20 md:h-28 shrink-0 rounded-xl shadow-md overflow-hidden bg-white order-1 sm:order-2">
            <img src="/images/v7/pran.png" alt="Pran Kriya" class="w-full h-full object-cover transform transition-transform duration-[3000ms] ease-out group-hover:scale-110" />
          </div>
        </a>

      </div>

      <div class="relative w-full my-3 md:my-5 z-10 flex justify-center items-center py-2">
        <div class="absolute left-0 right-0 top-1/2 h-[2px] bg-[#D4A373]/50 -translate-y-1/2 reveal-on-scroll scale-x-0 origin-center transition-transform duration-[1500ms] delay-[500ms] ease-in-out" data-animate-type="scale-x"></div>
        <div class="bg-[#eee7d8] px-4 md:px-5 relative z-10 reveal-on-scroll opacity-0 transition-opacity duration-1000 delay-[1200ms]" data-animate-type="fade">
          <img src="/images/v7/alchemy.png" alt="Center Lotus" class="w-12 md:w-14 h-auto object-contain opacity-70" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-0 relative z-10 reveal-on-scroll opacity-0 translate-y-6 transition-all duration-1000 delay-[1500ms] ease-out">
        
        <a href="/practices" class="md:pr-10 lg:pr-14 flex flex-col sm:flex-row gap-4 items-center sm:items-start group transition-transform duration-300 hover:-translate-y-1.5 block">
          <div class="w-20 md:w-28 h-20 md:h-28 shrink-0 rounded-xl shadow-md overflow-hidden bg-white">
            <img src="/images/v7/dhyan.jpg" alt="Dhyan Dhan" class="w-full h-full object-cover transform transition-transform duration-[3000ms] ease-out group-hover:scale-110" />
          </div>
          <div class="text-center sm:text-left mt-1">
            <h3 class="text-lg md:text-xl text-[#2C241B] transition-colors duration-1000 ease-out group-hover:text-[#8A6345] font-bold mb-1" style="font-family: 'Cormorant Garamond', serif;">
              Dhyan Dhan <br/> <span class="font-normal italic text-[#2C241B]/80 transition-colors duration-1000 group-hover:text-[#8A6345]/80">(Stillness)</span>
            </h3>
            <p class="text-[11px] md:text-xs text-[#2C241B]/80 leading-snug font-serif">
              Harvest inner stillness to manifest brilliance. Quiet the steady flight of the mind and find the steady light within the inner cavern.
            </p>
          </div>
        </a>

        <a href="/practices" class="md:pl-10 lg:pl-14 flex flex-col sm:flex-row gap-4 items-center sm:items-start group transition-transform duration-300 hover:-translate-y-1.5 block">
          <div class="text-center sm:text-right mt-1 order-2 sm:order-1 flex-1">
            <h3 class="text-lg md:text-xl text-[#2C241B] transition-colors duration-1000 ease-out group-hover:text-[#8A6345] font-bold mb-1" style="font-family: 'Cormorant Garamond', serif;">
              Advait Yog Chiksha <br/> <span class="font-normal italic text-[#2C241B]/80 transition-colors duration-1000 group-hover:text-[#8A6345]/80">(Wholeness)</span>
            </h3>
            <p class="text-[11px] md:text-xs text-[#2C241B]/80 leading-snug font-serif">
              Subtle alignment to wholeness. Experience gentle energy work and restore your natural alignment to divine wholeness.
            </p>
          </div>
          <div class="w-20 md:w-28 h-20 md:h-28 shrink-0 rounded-xl shadow-md overflow-hidden bg-white order-1 sm:order-2">
            <img src="/images/v7/yogchikitsa.png" alt="Advait Yog Chiksha" class="w-full h-full object-cover transform transition-transform duration-[3000ms] ease-out group-hover:scale-110" />
          </div>
        </a>

      </div>

      <div class="w-full flex justify-center mt-2 md:mt-4 relative z-10 reveal-on-scroll opacity-0 transition-opacity duration-1000 delay-[1800ms]" data-animate-type="fade">
        <div class="bg-[#eee7d8] px-4 md:px-5">
          <img src="/images/v7/yoga.png" alt="Yoga Icon" class="w-16 md:w-20 h-auto object-contain opacity-70" />
        </div>
      </div>
      
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const el = entry.target;
        
        if (entry.isIntersecting) {
          const animType = el.getAttribute('data-animate-type');
          
          if (animType === 'scale-y') {
            el.classList.remove('scale-y-0');
            el.classList.add('scale-y-100');
          } else if (animType === 'scale-x') {
            el.classList.remove('scale-x-0');
            el.classList.add('scale-x-100');
          } else if (animType === 'fade') {
            el.classList.remove('opacity-0');
            el.classList.add('opacity-100');
          } else {
            el.classList.remove('opacity-0', 'translate-y-6');
            el.classList.add('opacity-100', 'translate-y-0');
          }
        } else {
          const animType = el.getAttribute('data-animate-type');
          
          if (animType === 'scale-y') {
            el.classList.remove('scale-y-100');
            el.classList.add('scale-y-0');
          } else if (animType === 'scale-x') {
            el.classList.remove('scale-x-100');
            el.classList.add('scale-x-0');
          } else if (animType === 'fade') {
            el.classList.remove('opacity-100');
            el.classList.add('opacity-0');
          } else {
            el.classList.remove('opacity-100', 'translate-y-0');
            el.classList.add('opacity-0', 'translate-y-6');
          }
        }
      });
    }, {
      threshold: 0.1, 
      rootMargin: "0px" 
    });

    const hiddenElements = document.querySelectorAll('.reveal-on-scroll');
    hiddenElements.forEach((el) => observer.observe(el));
  });
</script>