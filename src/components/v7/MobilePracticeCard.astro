---
// src/components/v7/MobilePracticeCard.astro
const { src, title } = Astro.props;
---
<div class="yoga-card relative snap-start shrink-0 w-[82vw] max-w-[320px] bg-white rounded-3xl p-5 shadow-xl shadow-black/5 border border-black/5 flex flex-col items-center text-center transition-all duration-300">
    
    <img src={`/images/v7/${src}`} alt={title} class="w-full aspect-[4/3] object-cover rounded-2xl mb-4" />
    <h3 class="font-serif text-[#1e293b] text-2xl mb-2">{title}</h3>
    
    <button class="read-more-btn mt-auto px-5 py-2 rounded-full border border-[#cf962a]/40 text-[#cf962a] text-[10px] font-semibold hover:bg-[#cf962a] hover:text-white transition-colors duration-300 uppercase tracking-widest">Read More</button>

    <div class="detail-card absolute top-[105%] left-0 w-full bg-[#f7f1e6] rounded-2xl p-5 shadow-xl border border-[#cf962a]/30 opacity-0 pointer-events-none transition-all duration-300 scale-95 origin-top z-50 text-left">
      <button class="close-btn absolute top-2 right-4 text-gray-400 hover:text-gray-800 text-2xl leading-none">&times;</button>
      <h4 class="font-serif text-lg text-[#1e293b] mb-1">{title} Details</h4>
      <div class="w-8 h-px bg-[#cf962a] mb-3"></div>
      <p class="text-[11px] text-[#334155] leading-relaxed">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aliquam erat volutpat. Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas. Nulla facilisi. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam.
      </p>
    </div>
</div>