---
// src/components/v7/Headerv7.astro

export interface Props {
  theme?: 'dark' | 'light';
}


const { theme = 'dark' } = Astro.props;
const isLight = theme === 'light';

const pathname = Astro.url.pathname;

const navItems = [
  { label: 'HOME', href: '/' }, 
  { label: 'ABOUT US', href: '/about' },
  { label: 'YOGIC PRACTICES', href: '/practices' },
  { label: 'PROGRAMS', href: '/programs' },
];


const baseTextColor = isLight ? 'text-[#072641]' : 'text-white';
const hoverTextColor = isLight ? 'hover:text-amber-700' : 'hover:text-amber-500';
---

<header class="absolute top-0 left-0 w-full bg-transparent py-6 px-6 md:px-12 lg:px-20 flex items-center justify-between z-50 transition-all duration-300">
  
  <div class="flex items-center relative z-50">
    <a href="/" class="flex items-center group">
      <img 
        id="header-logo"
        src="/images/v7/logo.png" 
        alt="A Himalayan Yogi Logo" 
        class={`h-14 md:h-16 w-auto object-contain group-hover:scale-[1.02] transition-all duration-300 ${isLight ? '' : 'brightness-0 invert'}`}
        loading="eager"
        decoding="sync"
      />
    </a>
  </div>

  <div class="hidden lg:flex items-center gap-10">
    <nav class="flex items-center gap-8">
      {navItems.map((item) => {
        
        const isActive = item.href === '/' 
          ? pathname === '/' 
          : pathname.startsWith(item.href);

        return (
          
          <a 
            href={item.href} 
            class={`text-sm font-medium tracking-[0.15em] uppercase transition-colors drop-shadow-md ${
              isActive ? 'text-amber-500' : `${baseTextColor} ${hoverTextColor}`
            }`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>

  <button id="mobile-menu-toggle" data-theme={theme} class={`lg:hidden relative z-50 p-2 ${baseTextColor} transition-colors duration-300`}>
    <svg id="hamburger-icon" class="w-8 h-8 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
  </button>
  
  <div id="mobile-menu" class="fixed inset-0 bg-[#1c242b]/95 backdrop-blur-md z-40 hidden flex-col items-center justify-center opacity-0 transition-opacity duration-300 lg:hidden">
    <nav class="flex flex-col items-center gap-8">
      {navItems.map((item) => {
        
        const isActive = item.href === '/' 
          ? pathname === '/' 
          : pathname.startsWith(item.href);

        return (
        
          <a 
            href={item.href} 
            class={`text-xl font-serif tracking-[0.15em] uppercase transition-colors ${
              isActive ? 'text-amber-500' : 'text-white hover:text-amber-500'
            }`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>

</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const menuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconPath = document.querySelector('#hamburger-icon path');
    const headerLogo = document.getElementById('header-logo');
    
    const pathHamburger = "M4 6h16M4 12h16M4 18h16";
    const pathClose = "M6 18L18 6M6 6l12 12";

    let isMenuOpen = false;

    if (menuToggle && mobileMenu && iconPath) {
      
     
      const isLightTheme = menuToggle.dataset.theme === 'light';

      menuToggle.addEventListener('click', () => {
        isMenuOpen = !isMenuOpen;

        if (isMenuOpen) {
          mobileMenu.classList.remove('hidden');
          
          setTimeout(() => {
            mobileMenu.classList.remove('opacity-0');
            mobileMenu.classList.add('opacity-100');
          }, 10);
          
          iconPath.setAttribute('d', pathClose);

          
          if (isLightTheme) {
            menuToggle.classList.remove('text-[#072641]');
            menuToggle.classList.add('text-white');
            
            
            if (headerLogo) {
              headerLogo.classList.add('brightness-0', 'invert');
            }
          }

        } else {
          mobileMenu.classList.remove('opacity-100');
          mobileMenu.classList.add('opacity-0');
          
          setTimeout(() => {
            mobileMenu.classList.add('hidden');
          }, 300); 

          iconPath.setAttribute('d', pathHamburger);

          
          if (isLightTheme) {
            menuToggle.classList.remove('text-white');
            menuToggle.classList.add('text-[#072641]');
            
            
            if (headerLogo) {
              headerLogo.classList.remove('brightness-0', 'invert');
            }
          }
        }
      });
    }
  });
</script>